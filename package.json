{
  "name": "mdk-cim-navigator",
  "description": "Navigate SAP MDK CIM overrides directly from the editor.",
  "publisher": "ShailendraKumar",
  "displayName": "MDK CIM Navigator",
  "version": "0.0.3",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Debuggers"
  ],
  "activationEvents": [
    "workspaceContains:**/*.cim"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
